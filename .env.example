# ============================================================
# Dreams & Omens — publish-post.mjs environment
# Copy this file to `.env` (in the same folder) and fill in the real values.
# `.env` is git-ignored — do NOT commit it.
#
# This file is SEPARATE from .env.local (which the Next.js app uses).
# Only the publish-post script reads .env, and it only needs these two values.
# ============================================================

# Found in: Supabase Dashboard → Project Settings → API Keys → Project URL
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# Found in: Supabase Dashboard → Project Settings → API Keys → service_role (secret)
# This key bypasses row-level security. Keep it secret. Never share or commit it.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...paste-your-service-role-key-here
