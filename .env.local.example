# ============================================================
# Dreams & Omens — Environment Variables
# Copy this file to .env.local and fill in every value.
# NEVER commit .env.local to git.
# ============================================================

# ── App ──────────────────────────────────────────────────────
# Full URL of your deployment (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000


# ── Supabase ─────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
#
# NEXT_PUBLIC_ prefix = safe to expose to the browser
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key — SERVER ONLY, never prefix with NEXT_PUBLIC_
# Used for admin operations (e.g., from webhook route)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...


# ── OpenAI ───────────────────────────────────────────────────
# Found in: platform.openai.com → API Keys
# SERVER ONLY — never prefix with NEXT_PUBLIC_
OPENAI_API_KEY=sk-...


# ── Stripe ───────────────────────────────────────────────────
# Found in: dashboard.stripe.com → Developers → API Keys
# SERVER ONLY — never prefix with NEXT_PUBLIC_
STRIPE_SECRET_KEY=sk_test_...

# Publishable key IS safe for the browser (used in future checkout redirects)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Webhook signing secret — get this from:
#   Stripe Dashboard → Developers → Webhooks → your endpoint → Signing secret
#   OR: stripe listen --forward-to localhost:3000/api/stripe/webhook  (local dev)
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs — create these products in Stripe Dashboard first:
#   Basic:    $2.99/month recurring subscription
#   Reflect+: $4.99/month recurring subscription
# Then paste the generated price_xxx IDs here.
STRIPE_PRICE_BASIC_MONTHLY=price_...
STRIPE_PRICE_REFLECT_PLUS_MONTHLY=price_...

# Gate-screen first-month coupons (server-applied when source=gate, not customer-entered)
# Basic:    fixed $2.00 off, duration=once → $2.99 becomes $0.99 for first month
# Reflect+: fixed $4.00 off, duration=once → $4.99 becomes $0.99 for first month
STRIPE_COUPON_GATE_BASIC=
STRIPE_COUPON_GATE_REFLECT_PLUS=
# Note: the DREAMS2 promo code (email popup offer, 2 months at $0.99) is a customer-entered
# Promotion Code in Stripe — no env var needed. See setup notes.
